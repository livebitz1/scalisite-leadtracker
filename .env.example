# ScaliSite Lead Tracker — environment variables
# Copy this file to .env.local and fill in real values.

# Neon Postgres pooled connection string (pooler host).
# Append ?pgbouncer=true&connection_limit=1 when using the pooler.
# Example:
# DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
DATABASE_URL=

# Optional: direct (non-pooled) connection used by Prisma for migrations.
# Use the non-pooler Neon host here. If omitted, DATABASE_URL is used.
# DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Secret used to encrypt NextAuth JWTs. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the app (required in production; optional in local dev).
NEXTAUTH_URL=http://localhost:3000

# Admin sign-in. The admin authenticates with this password only (no email).
# This value is the source of truth for admin auth — not the database.
ADMIN_PASSWORD=
# Optional display name for the admin account (defaults to "Administrator").
ADMIN_NAME="Administrator"
